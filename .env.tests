# Postgres
POSTGRES_DB=tests_deepmtg
POSTGRES_USER=tests_deepmtg_user
POSTGRES_PASSWORD=""
POSTGRES_HOST=db
POSTGRES_PORT=5432

# AI Service
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MAX_TOKENS=40000
OLLAMA_NUM_CTX=32768
TEXT_MODEL=deepseek:deepseek-chat
TOOL_MODEL_BASIC=deepseek:deepseek-chat
TOOL_MODEL_THINKING=deepseek:deepseek-reasoner
GOOGLE_API_KEY=""
DEEPSEEK_API_KEY=""
MAX_AGENT_CALLS_PER_TASK=100
MAX_AGENT_INPUT_TOKENS=10000000
MAX_AGENT_OUTPUT_TOKENS=10000
EMBEDDING_MODEL="snowflake-arctic-embed2"
EMBEDDING_DIMENSION=1024

# Redis
REDIS_URL=redis://redis:6379/0

# Django
SECRET_KEY='django-insecure'
ALLOWED_HOSTS=["localhost","127.0.0.1", "web", "0.0.0.0"]
CSRF_TRUSTED_ORIGINS=[]

# Environment
ENVIRONMENT=development
DEBUG=True
LOCALITY="Asia/Tokyo"
PUBLIC_URL=""

# Celery
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TASK_DEFAULT_EXCHANGE=default
CELERY_TASK_DEFAULT_ROUTING_KEY=default
CELERY_TASK_CREATE_MISSING_QUEUES=False
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# qdrant
QDRANT_URL = "http://qdrant:6333"
HNSW_M = 16
HNSW_EF_CONSTRUCT = 128
HNSW_EF_SEARCH = 128

# Logfire
LOGFIRE_TOKEN=''
LOGFIRE_ENVIRONMENT=''

# Google Auth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_ENFORCE_ALLOWED_EMAILS="false"
GOOGLE_ALLOWED_EMAILS=[]

# BE Auth
JWT_ISSUER=""
JWT_AUDIENCE=""
JWT_SIGNING_KEY=""
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_RATE_LIMIT_FAIL_OPEN=False
AUTH_RATE_LIMIT_TRUSTED_PROXY_CIDRS=[]
ADMIN_ALLOWLIST_CIDRS=["127.0.0.1/32"]

# Limits
DECK_BUILDS_PER_DAY=10
DECK_BUILD_RETRY_LIMIT=3

# Guardrails
RELEVANCY_THRESHOLD=0.6
N_WARNINGS_BEFORE_BLOCK=5
