{$PUBLIC_URL}:3000 {

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "interest-cohort=()"
  }

  encode zstd gzip

  log {
    output stdout
    format console
  }

  @nextauth path /api/auth/*
  handle @nextauth {
    reverse_proxy {$FRONTEND_UPSTREAM} {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto {scheme}
      header_up X-Forwarded-For {remote_host}
    }
  }

  handle_path /static/* {
    root * /srv/static
    file_server
  }

  handle_path /media/* {
    root * /srv/media
    file_server
  }

  @backend {
    path /api/* /admin/*
    not path /api/auth/*
  }
  handle @backend {
    reverse_proxy {$BACKEND_UPSTREAM} {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto {scheme}
      header_up X-Forwarded-For {remote_host}
    }
  }

  handle {
    reverse_proxy {$FRONTEND_UPSTREAM} {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto {scheme}
      header_up X-Forwarded-For {remote_host}
    }
  }
}


